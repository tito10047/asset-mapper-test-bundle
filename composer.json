{
    "name": "tito10047/asset-mapper-test-bundle",
    "description": "A Symfony bundle that bridges the gap between Symfony AssetMapper and Node.js test runners by creating a symlink-based node_modules structure from your import map.",
    "type": "symfony-bundle",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Tito10047\\AssetMapperTestBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tito10047\\AssetMapperTestBundle\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Jozef Môstka",
            "email": "jozef@mostka.sk"
        }
    ],
    "require": {
        "php": ">=8.4",
        "symfony/console": "^6.4|^7.4|^8.0",
        "symfony/dependency-injection": "^6.4|^7.4|^8.0",
        "symfony/filesystem": "^6.4|^7.4|^8.0",
        "symfony/http-kernel": "^6.4|^7.4|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/framework-bundle": "^6.4|^7.4|^8.0"
    }
}
